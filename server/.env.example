# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Auth
JWT_ACCESS_SECRET="your_access_secret_here_change_in_prod"
JWT_REFRESH_SECRET="your_refresh_secret_here_change_in_prod"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Google Fit OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/oauth/callback/google"

# Fitbit OAuth
FITBIT_CLIENT_ID="your_fitbit_client_id"
FITBIT_CLIENT_SECRET="your_fitbit_client_secret"
FITBIT_REDIRECT_URI="http://localhost:3001/api/auth/oauth/callback/fitbit"

# Stripe (disabled by default)
ENABLE_REAL_PAYMENTS=false
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your_app_password"

# App
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# Cron
SETTLEMENT_CRON="0 0 * * *"
PANIC_CRON_1="0 23 * * *"
PANIC_CRON_2="30 23 * * *"
PANIC_CRON_3="52 23 * * *"
STEP_SYNC_CRON="*/30 * * * *"
