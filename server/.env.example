# =============================================
# STEPPA CHALLENGE — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# --- Supabase / PostgreSQL ---
# Get these from: https://supabase.com/dashboard/project/sxcwqkaufujgsqbsjqgp/settings/database
# Under "Connection string" -> select "URI" -> use Transaction pooler for DATABASE_URL
# Use Session pooler or direct for DIRECT_URL
DATABASE_URL="postgresql://postgres.sxcwqkaufujgsqbsjqgp:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.sxcwqkaufujgsqbsjqgp:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- JWT Auth ---
JWT_ACCESS_SECRET="change-this-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-this-to-a-different-long-random-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# --- Google Fit OAuth (optional - manual steps work without this) ---
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/oauth/callback/google"

# --- Fitbit OAuth (optional) ---
FITBIT_CLIENT_ID="your_fitbit_client_id"
FITBIT_CLIENT_SECRET="your_fitbit_client_secret"
FITBIT_REDIRECT_URI="http://localhost:3001/api/auth/oauth/callback/fitbit"

# --- Stripe (disabled by default, virtual coins used instead) ---
ENABLE_REAL_PAYMENTS=false
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Email (optional for notifications) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your_app_password"

# --- App ---
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# --- Cron Schedules ---
SETTLEMENT_CRON="0 0 * * *"
PANIC_CRON_1="0 23 * * *"
PANIC_CRON_2="30 23 * * *"
PANIC_CRON_3="52 23 * * *"
STEP_SYNC_CRON="*/30 * * * *"
